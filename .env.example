# ═══════════════════════════════════════
# ArchiDZ — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs
# ═══════════════════════════════════════

# Base de données PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/archidz"

# NextAuth.js
# Génère avec: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary (stockage fichiers & images)
# Inscription gratuite sur cloudinary.com
CLOUDINARY_CLOUD_NAME="ton-cloud-name"
CLOUDINARY_API_KEY="ton-api-key"
CLOUDINARY_API_SECRET="ton-api-secret"

# Chargily Pay (paiement algérien)
# Inscription sur chargily.com
CHARGILY_API_KEY="test_sk_xxxxxxxxxxxxxxxxxxxxxxxx"
CHARGILY_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"
CHARGILY_BASE_URL="https://pay.chargily.net/test/api/v2"
# En production: https://pay.chargily.net/api/v2

# Email (Nodemailer)
# Utilise Gmail ou Brevo (ex-Sendinblue)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="ton-email@gmail.com"
SMTP_PASS="ton-app-password"
SMTP_FROM="ArchiDZ <noreply@archidz.dz>"

# Commission plateforme (%)
NEXT_PUBLIC_COMMISSION_RATE="12"

# URL de l'app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
